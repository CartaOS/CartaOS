# ===================================================================
# Secrets and Environment Variables
# CRITICAL: Never commit sensitive information.
# ===================================================================
.env
.env.*
!.env.example

# ===================================================================
# IDE and Editor directories
# User-specific settings that should not be committed.
# ===================================================================
.vscode/
.idea/
.sublime-project
.sublime-workspace

# ===================================================================
# CartaOS Pipeline Data
# Ignore all content inside pipeline stages to prevent committing user data,
# but keep the directory structure using the .gitkeep files.
# ===================================================================
/00_Inbox/*
/01_Library/*
/02_Triage/*
/03_Lab/*
/04_ReadyForOCR/*
/05_ReadyForSummary/*
/06_TooLarge/*
/07_Processed/*
!/*/.gitkeep

# ===================================================================
# Python / Backend artifacts
# Virtual environments, caches, build artifacts, and test reports.
# ===================================================================
/.venv/
/venv/
/env/
__pycache__/
*.py[cod]
*.so
/dist/
/build/
/*.egg-info/
.pytest_cache/
.coverage
/htmlcov/

# ===================================================================
# Frontend (Node.js / Svelte / Vite) artifacts
# Dependencies, build output, and logs.
# ===================================================================
/frontend/node_modules/
/frontend/.svelte-kit/
/frontend/build/
/frontend/dist/
/frontend/npm-debug.log*
/frontend/yarn-error.log*
/frontend/pnpm-debug.log*
/frontend/e2e-artifacts/

# ===================================================================
# Tauri / Rust artifacts
# Compiled code and build output from the Rust backend.
# ===================================================================
/src-tauri/target/

# ===================================================================
# Project-specific Tools & Logs
# Caches and logs from tools used in the development workflow.
# ===================================================================
.ScanTailor/
.gemini/
*.log
/cartaos-install.log
/coverage.xml

# ===================================================================
# Operating System specific files
# Junk files created by macOS, Windows, and Linux.
# ===================================================================
.DS_Store
._*
Thumbs.db
desktop.ini

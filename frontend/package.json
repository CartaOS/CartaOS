{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"test": "vitest",
		"test:run": "vitest run",
		"e2e": "playwright test && pkill -f 'vite preview' || true",
		"perf": "npm run build && npm run preview & sleep 3 && node scripts/lighthouse-ci.mjs && kill %1",
		"perf:e2e": "playwright test e2e/performance.spec.ts",
		"visual:test": "playwright test e2e/visual-regression.spec.ts",
		"visual:update": "playwright test e2e/visual-regression.spec.ts --update-snapshots"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.10.2",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@playwright/test": "^1.47.1",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/typography": "^0.5.14",
		"@testing-library/jest-dom": "^6.6.4",
		"@testing-library/svelte": "^5.2.8",
		"@types/jest-axe": "^3.5.9",
		"@vitest/browser": "3.2.4",
		"@vitest/coverage-v8": "^3.2.4",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-storybook": "^9.1.3",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"jest-axe": "^10.0.0",
		"jsdom": "^26.1.0",
		"lighthouse": "^12.8.1",
		"playwright": "^1.55.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.9",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^7.0.4",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.9",
		"@tauri-apps/api": "^2.8.0"
	},
	"overrides": {
		"cookie": "^1.0.2"
	}
}
